  (text "Temperature Sensors" (at 100 150) (effects (font (size 3 3)) (justify center)) (uuid "sensor_title"))
  (text "• 1x Die internal (0.5°C res)\n• 3x Ambient NTC thermistors\n• 1x MOSFET temperature\n\nAll connected via I2C\nto thermal controller" (at 100 185) (effects (font (size 2)) (justify center)) (uuid "sensor_details"))

