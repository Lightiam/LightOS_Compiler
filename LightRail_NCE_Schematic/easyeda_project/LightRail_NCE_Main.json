  "design_notes": [
    "Hierarchical schematic with detailed subsystem sheets for manufacturability",
    "All power planes referenced to ground planes for low inductance",
    "Differential pair routing for PCIe and memory interfaces",
    "Comprehensive decoupling strategy across all voltage rails",
    "Thermal design validated for 225W continuous operation",
    "Full testability via JTAG and I2C interfaces",
    "Modeled after NVIDIA RTX GPU reference designs"
  ],

  "manufacturing_notes": [
    "BGA placement tolerance: ±0.05mm (Cpk >1.33)",
    "Micro-bump assembly for HBM3 stacks requires specialized equipment",
    "X-ray inspection required for BGA/HBM3 solder quality",
    "Thermal cycling validation: 3 cycles -20 to +80°C",
    "Assembly sequence: Solder paste → Place (pick & place for passives, manual BGA) → Reflow → Inspection",
    "Lead-free Pb-free reflow profile, peak 250-260°C",
    "Workmanship standard: IPC-A-610E Class 2"
  ]
