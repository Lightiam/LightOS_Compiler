{
  "name": "LightRail AI NCE Motherboard",
  "description": "Neural Computing Engine - PCIe x16 GPU-like Accelerator with HBM3 Memory",
  "version": "1.0",
  "created": "2026-07-19",
  "updated": "2026-07-19",
  "author": "LightRail AI Engineering",
  "license": "Proprietary",

  "project_info": {
    "title": "LightRail AI NCE - Complete Reference Design",
    "subtitle": "1.5 TFLOPS FP32 @ 2.4 GHz | 192GB HBM3 | 225W Typical",
    "board_dimensions": {
      "length_mm": 267,
      "width_mm": 111,
      "thickness_mm": 2.4
    },
    "form_factor": "PCIe x16 Dual-Slot",
    "pcb_layers": 10
  },

  "system_specifications": {
    "processing_power": "1.5 TFLOPS FP32 @ 2.4 GHz",
    "memory": {
      "type": "HBM3",
      "capacity_gb": 192,
      "stacks": 12,
      "bandwidth_gbs": 256
    },
    "power": {
      "typical_w": 225,
      "peak_w": 275,
      "vcore_v": 0.9,
      "vcore_a": 210,
      "vmem_v": 1.2,
      "vmem_a": 75
    },
    "thermal": {
      "typical_temp_c": "65-75",
      "max_temp_c": 100,
      "throttle_temp_c": 85,
      "shutdown_temp_c": 95
    }
  },

  "main_subsystems": [
    {
      "id": "pdn",
      "name": "Power Delivery Network",
      "file": "LightRail_NCE_PDN.sch.json",
      "description": "12-Phase PWM power delivery, 0.9V core @ 210A, 1.2V memory @ 75A",
      "key_components": [
        "MP5949 PWM Controller",
        "24x CSD95481RWJ MOSFETs",
        "12x 0.47µH Phase Inductors",
        "~600 MLCCs for decoupling"
      ]
    },
    {
      "id": "pcie",
      "name": "PCIe Interface",
      "file": "LightRail_NCE_PCIe.sch.json",
      "description": "PCIe x16 Gen4 edge connector with 75W power delivery and protection",
      "key_components": [
        "PCIe x16 edge connector (164-pin)",
        "Schottky OR-ing diodes (power merging)",
        "PTC fuses (protection)",
        "AC coupling capacitors"
      ]
    },
    {
      "id": "memory",
      "name": "HBM3 Memory Subsystem",
      "file": "LightRail_NCE_Memory.sch.json",
      "description": "12x 16GB HBM3 stacks with 256 GB/s aggregate bandwidth",
      "key_components": [
        "12x SK Hynix H58M16ABHX (16GB each)",
        "~96 MLCC decoupling capacitors",
        "128-bit data interfaces (1,024 total)",
        "Source-sync timing network"
      ]
    },
    {
      "id": "clock",
      "name": "Clock Distribution",
      "file": "LightRail_NCE_Clock.sch.json",
      "description": "27MHz TCXO reference with on-chip PLL (x88.9) to 2.4 GHz",
      "key_components": [
        "NDK SG-531S TCXO (27 MHz ±50 ppm)",
        "On-chip PLL (2.4 GHz output)",
        "Differential clock routing (100Ω)",
        "Skew control (<100ps max)"
      ]
    },
    {
      "id": "thermal",
      "name": "Thermal Management",
      "file": "LightRail_NCE_Thermal.sch.json",
      "description": "Dual 40mm fans with PWM control and temperature monitoring",
      "key_components": [
        "2x 40mm DC Axial Fans (Delta/Noctua)",
        "5x Temperature sensors (1 internal + 4 external)",
        "Aluminum heatspreader (Al 6061-T6)",
        "Thermal interface material (Arctic MX-4)"
      ]
    },
    {
      "id": "debug",
      "name": "Debug & Test Interface",
      "file": "LightRail_NCE_Debug.sch.json",
      "description": "14-pin JTAG with boundary scan and I2C monitoring bus",
      "key_components": [
        "14-pin JTAG TAP header (IEEE 1149.1)",
        "3,136-cell boundary scan chain",
        "I2C bus (5x INA226 monitors, 3x LM75 sensors)",
        "Test access points (50+ pads)"
      ]
    }
  ],

  "power_rails": [
    {
      "name": "Vcore",
      "voltage": "0.9V",
      "tolerance": "±3%",
      "max_current_a": 210,
      "source": "12-Phase PDM",
      "destination": "LR-GEN3-NPU core"
    },
    {
      "name": "Vmem",
      "voltage": "1.2V",
      "tolerance": "±3%",
      "max_current_a": 75,
      "source": "Buck converter",
      "destination": "HBM3 memory stacks"
    },
    {
      "name": "V5",
      "voltage": "5.0V",
      "tolerance": "±5%",
      "max_current_a": 20,
      "source": "PTC fuse + LDO",
      "destination": "Fan PWM, sensors, aux"
    },
    {
      "name": "V3.3",
      "voltage": "3.3V",
      "tolerance": "±5%",
      "max_current_a": 2.5,
      "source": "LDO regulator",
      "destination": "I/O logic, oscillator"
    },
    {
      "name": "V1.8",
      "voltage": "1.8V",
      "tolerance": "±5%",
      "max_current_a": 1.5,
      "source": "LDO regulator",
      "destination": "JTAG, I2C, digital logic"
    }
  ],

  "connectors": [
